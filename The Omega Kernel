# %% Cell 2 — Spatial Encoder
class SpatialEncoder(nn.Module):
    def __init__(self, config: Config):
        super().__init__()
        self.config = config
        self.max_cells = config.max_grid_size * config.max_grid_size
        self.color_embed = nn.Embedding(
            config.n_colors + 1, config.d_model, padding_idx=10)
        self.pos_embed = nn.Embedding(self.max_cells, config.d_model)
        self.attention = nn.MultiheadAttention(
            embed_dim=config.d_model, num_heads=1,
            dropout=config.dropout, batch_first=True)
        self.norm1 = nn.LayerNorm(config.d_model)
        self.ffn = nn.Sequential(
            nn.Linear(config.d_model, config.d_ff),
            nn.GELU(),
            nn.Dropout(config.dropout),
            nn.Linear(config.d_ff, config.d_model))
        self.norm2 = nn.LayerNorm(config.d_model)

    def forward(self, grid: torch.Tensor) -> torch.Tensor:
        device = grid.device
        cells = grid.flatten()
        n_cells = cells.shape[0]
        positions = torch.arange(n_cells, device=device)
        x = self.color_embed(cells) + self.pos_embed(positions)
        x = x.unsqueeze(0)
        attended, _ = self.attention(x, x, x)
        x = self.norm1(x + attended)
        ff = self.ffn(x)
        x = self.norm2(x + ff).squeeze(0)
        return x


# %% Cell 3 — Mirror Transformer Block
class MirrorTransformerBlock(nn.Module):
    def __init__(self, config: Config):
        super().__init__()
        self.config = config
        self.cross_attention = nn.MultiheadAttention(
            embed_dim=config.d_model, num_heads=config.n_heads,
            dropout=config.dropout, batch_first=True)
        self.self_attention = nn.MultiheadAttention(
            embed_dim=config.d_model, num_heads=config.n_heads,
            dropout=config.dropout, batch_first=True)
        self.ffn = nn.Sequential(
            nn.Linear(config.d_model, config.d_ff),
            nn.GELU(),
            nn.Dropout(config.dropout),
            nn.Linear(config.d_ff, config.d_model),
            nn.Dropout(config.dropout))
        self.layer_norm1 = nn.LayerNorm(config.d_model)
        self.layer_norm2 = nn.LayerNorm(config.d_model)
        self.layer_norm3 = nn.LayerNorm(config.d_model)

    def forward(self, x_encoded: torch.Tensor,
                other_state: torch.Tensor) -> torch.Tensor:
        q = other_state.unsqueeze(0)
        kv = x_encoded.unsqueeze(0)
        attn_output, _ = self.cross_attention(query=q, key=kv, value=kv)
        attn_output = self.layer_norm1(attn_output + q)
        self_attn_output, _ = self.self_attention(
            query=attn_output, key=attn_output, value=attn_output)
        attn_output = self.layer_norm2(self_attn_output + attn_output)
        ff_out = self.ffn(attn_output)
        new_state = self.layer_norm3(ff_out + attn_output)
        return new_state.squeeze(0)


# %% Cell 4 — Field Monitor 3 (Stages 1-6)
class FieldMonitor3:
    """
    Computes all field variables at each refinement step.

    CRITICAL BUG FIX: check_EWS uses P_history[-2] not P_history[-1]
    because current P is already appended when check_EWS is called.

    CALIBRATION NOTE: All parameters must be re-estimated from the
    TRAINED model after training. Bootstrap estimates are not valid
    for production inference. A* must be 90th percentile of |A|
    from trained model. P_threshold must be below max observed P.
    """

    def __init__(self, config: Config, theta_bar: float, R: float,
                 K0: float, P0: float, A_star: float, alpha: float,
                 beta: float, lambda_val: float,
                 P_threshold: float = None):
        self.config = config
        self.theta_bar = theta_bar
        self.R = R
        self.K0 = K0
        self.P0 = P0
        self.A_star = A_star
        self.alpha = alpha
        self.beta = beta
        self.lambda_val = lambda_val
        self.P_threshold = P_threshold if P_threshold else P0 * 1.4
        self.history: List[float] = []
        self.A_history: List[float] = []
        self.K_history: List[float] = []
        self.gamma_history: List[float] = []
        self.P_history: List[float] = []
        self.EWS_history: List[bool] = []
        self.n_calm: int = 0

    def reset(self):
        self.history = []
        self.A_history = []
        self.K_history = []
        self.gamma_history = []
        self.P_history = []
        self.EWS_history = []
        self.n_calm = 0

    def compute_theta(self, y: torch.Tensor,
                      z: torch.Tensor) -> float:
        y_norm = F.normalize(y, dim=0)
        z_norm = F.normalize(z, dim=0)
        cosine_sim = torch.dot(y_norm, z_norm).item()
        cosine_sim = max(-1.0, min(1.0, cosine_sim))
        return 1.0 - cosine_sim

    def compute_A(self, theta: float) -> float:
        return theta - self.theta_bar

    def compute_P(self, tau: int) -> float:
        import math
        h_term = self.P0 * math.exp(-self.alpha * self.n_calm)
        s_term = 0.0
        window = min(tau, 20)
        for k in range(1, window + 1):
            if len(self.A_history) >= k:
                a_val = abs(self.A_history[-k])
                s_term += self.beta * a_val * math.exp(
                    -self.lambda_val * k)
        return max(0.01, min(2.0, h_term + s_term))

    def compute_K(self, A: float, P: float) -> float:
        import math
        return self.K0 * math.exp(A * P)

    def compute_gamma(self, K: float) -> float:
        return self.K0 / K

    def check_EWS(self, theta: float, P: float) -> bool:
        A = abs(self.compute_A(theta))
        calm = A < self.A_star
        # CRITICAL: use [-2] not [-1] — current P already appended
        rising_P = (len(self.P_history) >= 2 and
                    P > self.P_history[-2])
        elevated_P = P > self.P_threshold
        return calm and rising_P and elevated_P

    def step(self, y: torch.Tensor, z: torch.Tensor,
             tau: int = 0) -> float:
        theta = self.compute_theta(y, z)
        self.history.append(theta)
        A = self.compute_A(theta)
        self.A_history.append(A)
        P = self.compute_P(tau)
        self.P_history.append(P)
        if abs(A) > self.A_star:
            self.n_calm = 0
        else:
            self.n_calm += 1
        K = self.compute_K(A, P)
        gamma = self.compute_gamma(K)
        self.K_history.append(K)
        self.gamma_history.append(gamma)
        ews = self.check_EWS(theta, P)
        self.EWS_history.append(ews)
        return theta

    def is_converged(self, theta: float) -> bool:
        return theta < self.config.theta_threshold

    def summary(self) -> dict:
        if not self.history:
            return {}
        return {
            'steps': len(self.history),
            'trajectory': self.history,
            'theta_initial': self.history[0],
            'theta_final': self.history[-1],
            'theta_min': min(self.history),
            'theta_max': max(self.history),
            'converged': self.history[-1] < self.config.theta_threshold,
            'A_trajectory': self.A_history,
            'A_final': self.A_history[-1] if self.A_history else 0.0,
            'K_trajectory': self.K_history,
            'gamma_trajectory': self.gamma_history,
            'gamma_final': self.gamma_history[-1] if self.gamma_history else 1.0,
            'P_trajectory': self.P_history,
            'P_final': self.P_history[-1] if self.P_history else self.P0,
            'P_max': max(self.P_history) if self.P_history else self.P0,
            'EWS_trajectory': self.EWS_history,
            'EWS_fired': any(self.EWS_history),
            'EWS_count': sum(self.EWS_history),
            'w_y_final': 0.5,
            'w_z_final': 0.5,
        }


# %% Cell 5 — DRFMWUStage3 (Single Example, Full Stage 1-6)
class DRFMWUStage3(nn.Module):
    """
    Full DRF-MWU implementation Stages 1-6.
    Single-example encoding — the architecture that achieved
    67%+ cell accuracy and 95.8% transfer ratio.
    Exposes y_final, z_final, x_encoded for AIDA.
    """

    def __init__(self, cfg: Config, output_size: int,
                 theta_bar: float, R: float, K0: float,
                 P0: float = 0.5, A_star: float = 0.33,
                 alpha: float = 0.1, beta: float = 0.2,
                 lambda_val: float = 0.1):
        super().__init__()
        self.config = cfg
        self.encoder_y = SpatialEncoder(cfg)
        self.encoder_z = SpatialEncoder(cfg)
        self.block_y = MirrorTransformerBlock(cfg)
        self.block_z = MirrorTransformerBlock(cfg)
        self.cell_head = nn.Sequential(
            nn.Linear(cfg.d_model, cfg.d_model),
            nn.GELU(),
            nn.Linear(cfg.d_model, 10))
        object.__setattr__(self, 'monitor',
                          FieldMonitor3(cfg, theta_bar, R, K0,
                                        P0, A_star, alpha, beta,
                                        lambda_val))

    def compute_weights(self, gamma: float) -> tuple:
        w_z = 1.0 / (1.0 + gamma)
        w_y = 1.0 - w_z
        return w_y, w_z

    def pool(self, sequence: torch.Tensor) -> torch.Tensor:
        return sequence.mean(dim=0)

    def forward(self, x: torch.Tensor,
                output_shape: tuple = None,
                verbose: bool = False) -> Tuple[torch.Tensor, dict]:

        self.monitor.reset()
        y = self.encoder_y(x)
        z = self.encoder_z(x)
        x_encoded = ((y + z) / 2).detach()
        theta = self.monitor.step(self.pool(y), self.pool(z), tau=0)

        if verbose:
            print(f"  tau=0  theta={theta:.4f}  (initialization)")

        tau_star = 0
        w_y_history = []
        w_z_history = []

        for tau in range(1, self.config.tau_max + 1):
            y_new = self.block_y(x_encoded, z)
            z_new = self.block_z(x_encoded, y)
            y = y_new
            z = z_new
            theta = self.monitor.step(
                self.pool(y), self.pool(z), tau=tau)
            gamma = self.monitor.gamma_history[-1]
            w_y, w_z = self.compute_weights(gamma)
            w_y_history.append(w_y)
            w_z_history.append(w_z)

            if verbose:
                P_val = self.monitor.P_history[-1]
                ews = self.monitor.EWS_history[-1]
                print(f"  tau={tau}  theta={theta:.4f}  "
                      f"gamma={gamma:.3f}  P={P_val:.3f}  "
                      f"w_y={w_y:.3f}  w_z={w_z:.3f}  "
                      f"EWS={'🔴' if ews else '⚪'}")

            ews_fired = self.monitor.EWS_history[-1]
            if self.monitor.is_converged(theta) and not ews_fired:
                tau_star = tau
                if verbose:
                    print(f"  Converged at tau={tau}")
                break
            tau_star = tau

        if not w_y_history:
            w_y_history = [0.5]
            w_z_history = [0.5]

        w_y_final, w_z_final = w_y_history[-1], w_z_history[-1]
        h = w_y_final * y + w_z_final * z

        theta_final = self.monitor.history[-1] if self.monitor.history else 1.0
        P_final = self.monitor.P_history[-1] if self.monitor.P_history else self.monitor.P0
        ews_total = sum(self.monitor.EWS_history) if self.monitor.EWS_history else 0

        low_confidence = (
            theta_final > self.config.theta_threshold * 2 or
            ews_total > 2 or
            P_final > self.monitor.P_threshold)

        field_state = {
            'theta_final': theta_final,
            'P_final': P_final,
            'ews_total': ews_total,
            'tau_star': tau_star,
            'tau_max_reached': tau_star >= self.config.tau_max,
            'low_confidence': low_confidence,
            'w_y_final': w_y_final,
            'w_z_final': w_z_final,
            'gamma_final': self.monitor.gamma_history[-1],
            'A_final': self.monitor.A_history[-1]
        }

        if verbose and low_confidence:
            print(f"  ⚠️  Low confidence — AIDA intervention needed")

        if output_shape is not None:
            H_out, W_out = output_shape
            n_output_cells = H_out * W_out
            n_input_cells = h.shape[0]
            if n_output_cells <= n_input_cells:
                output_features = h[:n_output_cells]
            else:
                pad_size = n_output_cells - n_input_cells
                pad = h.mean(dim=0, keepdim=True).expand(pad_size, -1)
                output_features = torch.cat([h, pad], dim=0)
            output = self.cell_head(output_features)
        else:
            output = self.cell_head(h[0:1]).squeeze(0)

        info = self.monitor.summary()
        info['tau_star'] = tau_star
        info['w_y_history'] = w_y_history
        info['w_z_history'] = w_z_history
        info['w_y_final'] = w_y_final
        info['w_z_final'] = w_z_final
        info['field_state'] = field_state
        info['low_confidence'] = low_confidence
        info['y_final'] = y.detach()
        info['z_final'] = z.detach()
        info['x_encoded'] = x_encoded.detach()

        return output, info


# %% Cell 6 — ARC Data Utilities
def load_arc_dataset(data_path: str) -> list:
    puzzles = []
    for fname in sorted(os.listdir(data_path)):
        if fname.endswith('.json'):
            with open(os.path.join(data_path, fname)) as f:
                puzzle = json.load(f)
                puzzle['id'] = fname.replace('.json', '')
                puzzles.append(puzzle)
    return puzzles

def grid_to_tensor(grid: list,
                   device: torch.device = torch.device('cpu')) -> torch.Tensor:
    return torch.tensor(grid, dtype=torch.long, device=device)

