# %% Cell 10 — Loss Functions
def compute_task_loss(output, target):
    return F.cross_entropy(output, target.flatten())

def compute_field_loss(trajectory, P_trajectory=None):
    if len(trajectory) < 2:
        return torch.tensor(0.0)
    total = 0.0
    for i in range(1, len(trajectory)):
        increase = max(0.0, trajectory[i] - trajectory[i-1])
        P_w = (P_trajectory[i]
               if P_trajectory and i < len(P_trajectory) else 1.0)
        total += increase * P_w
    return torch.tensor((total / len(trajectory)) * 50.0 +
                        trajectory[-1] * 20.0)


# %% Cell 11 — Training Loop
def train_stage3(model, data_path, n_epochs=5, n_puzzles=300,
                 lr=3e-4, lambda_field=0.0,
                 device=torch.device('cpu')):
    optimizer = torch.optim.Adam(model.parameters(), lr=lr)
    puzzles = load_arc_dataset(data_path)[:n_puzzles]
    epoch_accs = []

    print("=" * 55)
    print("DRF-MWU Training")
    print("=" * 55)
    print(f"Puzzles: {n_puzzles}  Epochs: {n_epochs}  "
          f"LR: {lr}  Lambda: {lambda_field}")
    print("=" * 55)

    for epoch in range(n_epochs):
        model.train()
        losses, task_losses, field_losses, accs = [], [], [], []

        for puzzle in puzzles:
            for example in puzzle['train']:
                try:
                    x = grid_to_tensor(example['input'], device)
                    target = grid_to_tensor(example['output'], device)
                    if x.shape[0] > 30 or x.shape[1] > 30:
                        continue
                    H_out, W_out = target.shape
                    optimizer.zero_grad()
                    output, info = model(x, output_shape=(H_out, W_out))
                    task_loss = compute_task_loss(output, target)
                    field_loss = compute_field_loss(
                        info['trajectory'],
                        info.get('P_trajectory'))
                    total_loss = task_loss + lambda_field * field_loss
                    total_loss.backward()
                    torch.nn.utils.clip_grad_norm_(
                        model.parameters(), max_norm=1.0)
                    optimizer.step()
                    acc = (output.argmax(dim=-1) ==
                           target.flatten()).float().mean().item()
                    losses.append(total_loss.item())
                    task_losses.append(task_loss.item())
                    field_losses.append(field_loss.item())
                    accs.append(acc)
                except Exception:
                    continue

        mean_acc = float(np.mean(accs)) if accs else 0.0
        epoch_accs.append(mean_acc)
        print(f"Epoch {epoch+1}/{n_epochs}  "
              f"loss={np.mean(losses):.4f}  "
              f"task={np.mean(task_losses):.4f}  "
              f"field={np.mean(field_losses):.4f}  "
              f"cell_acc={mean_acc:.4f}")

    print(f"\nTraining complete.")
    print(f"Initial: {epoch_accs[0]:.4f}  "
          f"Final: {epoch_accs[-1]:.4f}  "
          f"Improvement: {epoch_accs[-1]-epoch_accs[0]:.4f}")
    return epoch_accs


