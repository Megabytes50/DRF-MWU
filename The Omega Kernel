# %% Cell 7 — Field Statistics Estimators
def estimate_field_statistics(model, data_path, n_puzzles=60,
                              device=torch.device('cpu')):
    print(f"Estimating field statistics from {n_puzzles} puzzles...")
    puzzles = load_arc_dataset(data_path)[:n_puzzles]
    all_thetas = []
    model.eval()
    with torch.no_grad():
        for i, puzzle in enumerate(puzzles):
            for example in puzzle['train']:
                try:
                    grid = grid_to_tensor(example['input'], device)
                    if grid.shape[0] > 30 or grid.shape[1] > 30:
                        continue
                    _, info = model(grid)
                    all_thetas.extend(info['trajectory'])
                except Exception:
                    continue
            if (i + 1) % 10 == 0:
                print(f"  Processed {i+1}/{n_puzzles} puzzles...")
    all_thetas = [t for t in all_thetas if 0.0 <= t <= 2.0]
    theta_bar = float(np.mean(all_thetas))
    R = float(max(all_thetas)) / 2
    K0 = 1.0 / (R ** 2)
    print(f"Field statistics:")
    print(f"  theta_bar: {theta_bar:.4f}")
    print(f"  R:         {R:.4f}")
    print(f"  K0:        {K0:.4f}")
    return {'theta_bar': theta_bar, 'R': R, 'K0': K0}


def estimate_p_parameters(model, data_path, n_puzzles=60,
                          device=torch.device('cpu')):
    print(f"Estimating P(tau) parameters from {n_puzzles} puzzles...")
    puzzles = load_arc_dataset(data_path)[:n_puzzles]
    all_A_abs = []
    model.eval()
    with torch.no_grad():
        for i, puzzle in enumerate(puzzles):
            for example in puzzle['train']:
                try:
                    grid = grid_to_tensor(example['input'], device)
                    if grid.shape[0] > 30 or grid.shape[1] > 30:
                        continue
                    _, info = model(grid)
                    all_A_abs.extend(
                        [abs(a) for a in info.get('A_trajectory', [])])
                except Exception:
                    continue
            if (i + 1) % 10 == 0:
                print(f"  Processed {i+1}/{n_puzzles} puzzles...")
    A_star = float(np.percentile(all_A_abs, 90))
    above = [a for a in all_A_abs if a > A_star]
    beta = float(np.mean(above)) * 0.5 if above else 0.1
    print(f"P(tau) parameters:")
    print(f"  P0:   0.5000")
    print(f"  A*:   {A_star:.4f}  (90th percentile)")
    print(f"  beta: {beta:.4f}")
    return {'P0': 0.5, 'A_star': A_star,
            'alpha': 0.1, 'beta': beta, 'lambda': 0.1}


