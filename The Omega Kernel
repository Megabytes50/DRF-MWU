                    [abs(a) for a in info.get('A_trajectory', [])])
            except Exception:
                continue

# Collect P values for P_threshold calibration
all_P = []
with torch.no_grad():
    for puzzle in load_arc_dataset(data_path)[:60]:
        for example in puzzle['train']:
            try:
                x = grid_to_tensor(example['input'], device)
                if x.shape[0] > 30 or x.shape[1] > 30:
                    continue
                H_out, W_out = grid_to_tensor(
                    example['output'], device).shape
                _, info = model3(x, output_shape=(H_out, W_out))
                all_P.extend(info.get('P_trajectory', []))
            except Exception:
                continue

A_star_trained = float(np.percentile(all_A_abs, 90))
P_threshold_trained = max(all_P) * 0.80 if all_P else 0.54

# Replace monitor with recalibrated version
new_monitor = FieldMonitor3(
    cfg,
    theta_bar=THETA_BAR, R=R, K0=K0,
    P0=0.5,
    A_star=A_star_trained,
    alpha=0.1,
    beta=p_params['beta'],
    lambda_val=0.1,
    P_threshold=P_threshold_trained)
object.__setattr__(model3, 'monitor', new_monitor)

print(f"Recalibrated:")
print(f"  A* (90th):    {A_star_trained:.4f}")
print(f"  P_threshold:  {P_threshold_trained:.4f}")

# Verify EWS fires
crack_events = ews_events = total_steps = 0
model3.eval()
with torch.no_grad():
    for puzzle in load_arc_dataset(data_path)[:100]:
        for example in puzzle['train']:
            try:
                x = grid_to_tensor(example['input'], device)
                if x.shape[0] > 30 or x.shape[1] > 30:
                    continue
                H_out, W_out = grid_to_tensor(
                    example['output'], device).shape
                _, info = model3(x, output_shape=(H_out, W_out))
                for a in info.get('A_trajectory', []):
                    if abs(a) > A_star_trained:
                        crack_events += 1
                ews_events += sum(info.get('EWS_trajectory', []))
                total_steps += len(info.get('A_trajectory', []))
            except Exception:
                continue

pct = crack_events / max(total_steps, 1) * 100
print(f"\nField Health:")
print(f"  Crack events: {crack_events} ({pct:.1f}%)")
print(f"  EWS events:   {ews_events}")
print(f"  Cracks 5-15%: {'✅' if 5 <= pct <= 20 else '❌'}")
print(f"  EWS firing:   {'✅' if ews_events > 0 else '❌'}")


# %% Cell 14 — Evaluation Functions
def evaluate_cell_and_exact(model, data_path, label,
                            n_puzzles=100,
                            device=torch.device('cpu')):
    puzzles = load_arc_dataset(data_path)[:n_puzzles]
    cell_accs, exact_matches, total = [], 0, 0
    model.eval()
    with torch.no_grad():
        for puzzle in puzzles:
            for example in puzzle['train']:
                try:
                    x = grid_to_tensor(example['input'], device)
                    target = grid_to_tensor(example['output'], device)
                    if x.shape[0] > 30 or x.shape[1] > 30:
                        continue
                    H_out, W_out = target.shape
                    output, _ = model(x, output_shape=(H_out, W_out))
                    preds = output.argmax(dim=-1)
                    tgt = target.flatten()
                    cell_accs.append(
                        (preds == tgt).float().mean().item())
                    exact_matches += int((preds == tgt).all().item())
                    total += 1
                except Exception:
                    continue
    acc = float(np.mean(cell_accs)) if cell_accs else 0.0
    print(f"{label}")
    print(f"  Cell accuracy: {acc:.4f}")
    print(f"  Exact matches: {exact_matches}/{total}")
    return {'cell_accuracy': acc,
            'exact_matches': exact_matches, 'total': total}


